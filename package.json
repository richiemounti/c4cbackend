{
  "name": "c4cbackend",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "tsc",
    "start": "node --dns-result-order=ipv4first ./dist/bin/www.js",
    "dev": "node --dns-result-order=ipv4first ./node_modules/ts-node-dev/lib/bin.js --respawn --transpile-only ./bin/www.ts",
    "lint": "eslint . --ext .ts",
    "seed:setup-tasks": "ts-node scripts/seedSetupTasks.ts",
    "reset:setup-data": "ts-node scripts/resetSetupData.ts",
    "update-tasks": "ts-node scripts/updateProjectTasks.ts",
    "update-tasks:apply": "ts-node scripts/updateProjectTasks.ts --apply",
    "update-tasks:project": "ts-node scripts/updateProjectTasks.ts --type=project",
    "update-tasks:site": "ts-node scripts/updateProjectTasks.ts --type=site",
    "update-tasks:project:apply": "ts-node scripts/updateProjectTasks.ts --type=project --apply",
    "update-tasks:site:apply": "ts-node scripts/updateProjectTasks.ts --type=site --apply",
    "check:bug-reports": "ts-node scripts/check-data-script.ts",
    "migrate:bug-reports": "ts-node scripts/simple-migration-script.ts",
    "build:migration": "tsc scripts/simple-migration-script.ts",
    "build:check": "tsc scripts/check-data-script.ts",
    "migrate:toc": "ts-node scripts/migrateTheoryOfChangeModels.ts",
    "reorder-tasks": "ts-node scripts/reorderSiteTasks.ts",
    "reorder-tasks:apply": "ts-node scripts/reorderSiteTasks.ts --apply",
    "fix-crops": "ts-node scripts/fixHorticulturalCrops.ts",
    "fix-crops:apply": "ts-node scripts/fixHorticulturalCrops.ts --apply",
    "migrate:villagers": "ts-node scripts/migrate-villagers-to-sites.ts",
    "migrate:villagers:apply": "ts-node scripts/migrate-villagers-to-sites.ts --apply",
    "reseed:stakeholder-options": "ts-node scripts/reseedStakeholderTaskOptions.ts"
  },
  "dependencies": {
    "@arcjet/node": "^1.0.0-beta.3",
    "@cloudinary/react": "^1.14.3",
    "@cloudinary/url-gen": "^1.22.0",
    "@google-cloud/storage": "^7.16.0",
    "@google-cloud/translate": "^9.3.0",
    "aws-sdk": "^2.1692.0",
    "bcryptjs": "^3.0.2",
    "bull": "^4.16.5",
    "cloudinary": "^2.8.0",
    "cookie-parser": "~1.4.4",
    "cors": "^2.8.5",
    "csv-parse": "^5.6.0",
    "debug": "~2.6.9",
    "dotenv": "^16.5.0",
    "express": "^4.21.2",
    "express-validator": "^7.2.1",
    "ioredis": "^5.7.0",
    "jsonwebtoken": "^9.0.2",
    "mongodb": "^6.14.2",
    "mongodb-memory-server": "^10.1.4",
    "mongoose": "^8.12.1",
    "morgan": "^1.10.1",
    "multer": "^1.4.5-lts.2",
    "node-cache": "^5.1.2",
    "nodemailer": "^6.10.1",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-microsoft": "^2.1.0",
    "socket.io": "^4.8.3",
    "stream-chat": "^9.28.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/bull": "^4.10.4",
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/debug": "^4.1.12",
    "@types/dotenv": "^8.2.3",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.13",
    "@types/node": "^20.17.23",
    "@types/nodemailer": "^6.4.17",
    "@types/passport": "^1.0.17",
    "@types/passport-google-oauth20": "^2.0.16",
    "@types/passport-microsoft": "^1.0.3",
    "@types/uuid": "^10.0.0",
    "eslint": "^9.21.0",
    "globals": "^16.0.0",
    "nodemon": "^3.1.9",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.26.0"
  }
}
