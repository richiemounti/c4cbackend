{
    "compilerOptions": {
      "target": "es6",
      "module": "commonjs",
      "outDir": "./dist",
      "rootDir": "./",
      "strict": true,
      "esModuleInterop": true,
      "skipLibCheck": true,
      "forceConsistentCasingInFileNames": true,
      "moduleResolution": "node",
      "resolveJsonModule": true,
      "sourceMap": true,
    },
    "include": [
      "**/*.ts",
      "migration-script.ts",
      "check-data-script.ts",
      "types/**/*.d.ts"
    ],
    "exclude": [
      "node_modules",
      "dist"
    ]
  }